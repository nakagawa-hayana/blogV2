{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "notion-to-md-proxy",
	"main": "src/index.ts",
	"compatibility_date": "2025-12-02",
	"observability": {
		"enabled": true
	},
	"dev": {
		"port": 3001
	},
	"services": [
		{
			"binding": "RUST",
			"service": "backend"
		},
		{
			"binding": "IMAGE_OPTIMIZER",
			"service": "image-optimizer"
		}
	],
	"vars": {
		"RUST_BACKEND_URL": "https://backend.adry.workers.dev"
	}
}
